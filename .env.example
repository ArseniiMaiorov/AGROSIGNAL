# База данных
DATABASE_URL=postgresql+asyncpg://agromap:agromap_dev_password@localhost:5432/agromap
DATABASE_URL_SYNC=postgresql+psycopg://agromap:agromap_dev_password@localhost:5432/agromap

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Sentinel Hub
SH_CLIENT_ID=
SH_CLIENT_SECRET=
SH_BASE_URL=https://services.sentinel-hub.com

# Погода
WEATHER_PROVIDER=openmeteo
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/3.0
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1

# Production / модели
MODE=production
ML_MODEL_PATH=models/boundary_unet_v2.onnx
ML_MODEL_NORM_STATS_PATH=models/boundary_unet_v2.norm.json
OBJECT_CLASSIFIER_PATH=models/object_classifier.pkl
OBJECT_MIN_SCORE=0.7
DEFAULT_CROP_CODE=wheat
YIELD_MODEL_VERSION=agronomy_tabular_v2
ARCHIVE_DIR=debug/archives
ARCHIVE_TTL_DAYS=30
SCENE_CACHE_DIR=cache/sentinel_scenes
SCENE_CACHE_TTL_DAYS=30
SH_RETRY_BUDGET=12
WEATHER_ALLOW_STALE_ON_FAILURE=true

# Auth / tenancy
AUTH_REQUIRED=true
AUTH_ACCESS_TTL_MINUTES=30
AUTH_REFRESH_TTL_DAYS=14
AUTH_JWT_SECRET=change-me-for-production
AUTH_BOOTSTRAP_ENABLED=true
AUTH_BOOTSTRAP_ORG_NAME=Default Organization
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@local
AUTH_BOOTSTRAP_ADMIN_PASSWORD=admin12345

# Imports / MLOps
DATA_IMPORT_DIR=debug/imports
DATA_IMPORT_MAX_ERRORS=100
MLFLOW_ENABLED=true
MLFLOW_TRACKING_URI=http://localhost:5000
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=autodetect-artifacts
